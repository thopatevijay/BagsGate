generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  FAN
  CREATOR
  ADMIN
}

enum SubscriptionTier {
  FREE
  PRO
  BUSINESS
}

enum TokenStatus {
  PRE_LAUNCH
  ACTIVE
  MIGRATED
}

enum GateType {
  AMOUNT
  TIERED
  TIME_LIMITED
}

enum ContentType {
  POST
  IMAGE
  VIDEO
  FILE
  LINK
}

enum NotificationType {
  NEW_CONTENT
  FEE_CLAIMABLE
  ACCESS_REVOKED
  ACCESS_GRANTED
  MILESTONE
  REFERRAL_SIGNUP
  SYSTEM
}

model User {
  id               String           @id @default(uuid())
  privyId          String           @unique @map("privy_id")
  walletAddress    String?          @unique @map("wallet_address")
  role             UserRole         @default(FAN)
  displayName      String?          @map("display_name")
  bio              String?
  avatarUrl        String?          @map("avatar_url")
  twitterHandle    String?          @map("twitter_handle")
  creatorSlug      String?          @unique @map("creator_slug")
  subscriptionTier SubscriptionTier @default(FREE) @map("subscription_tier")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  tokens        Token[]
  content       Content[]
  gates         Gate[]
  accessGrants  AccessGrant[]
  feeClaims     FeeClaim[]
  referralsMade Referral[]      @relation("referrer")
  referralsGot  Referral[]      @relation("referred")
  notifications Notification[]

  @@map("users")
}

model Token {
  id                String      @id @default(uuid())
  creatorId         String      @map("creator_id")
  mintAddress       String      @unique @map("mint_address")
  name              String
  symbol            String
  imageUrl          String?     @map("image_url")
  description       String?
  feeShareConfigKey String?     @map("fee_share_config_key")
  partnerConfigKey  String?     @map("partner_config_key")
  status            TokenStatus @default(PRE_LAUNCH)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  creator   User       @relation(fields: [creatorId], references: [id])
  gates     Gate[]
  feeClaims FeeClaim[]
  referrals Referral[]

  @@map("tokens")
}

model Gate {
  id                String   @id @default(uuid())
  creatorId         String   @map("creator_id")
  tokenId           String   @map("token_id")
  name              String
  description       String?
  gateType          GateType @map("gate_type")
  requiredAmount    BigInt   @map("required_amount")
  tierConfig        Json?    @map("tier_config")
  expiresAfterHours Int?     @map("expires_after_hours")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  creator      User          @relation(fields: [creatorId], references: [id])
  token        Token         @relation(fields: [tokenId], references: [id])
  content      Content[]
  accessGrants AccessGrant[]

  @@map("gates")
}

model Content {
  id          String      @id @default(uuid())
  creatorId   String      @map("creator_id")
  gateId      String?     @map("gate_id")
  title       String
  body        String
  contentType ContentType @map("content_type")
  mediaUrl    String?     @map("media_url")
  previewText String?     @map("preview_text")
  isPublished Boolean     @default(false) @map("is_published")
  publishedAt DateTime?   @map("published_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  creator User  @relation(fields: [creatorId], references: [id])
  gate    Gate? @relation(fields: [gateId], references: [id])

  @@map("content")
}

model AccessGrant {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  gateId       String    @map("gate_id")
  tokenBalance BigInt    @map("token_balance")
  grantedAt    DateTime  @default(now()) @map("granted_at")
  revokedAt    DateTime? @map("revoked_at")
  expiresAt    DateTime? @map("expires_at")

  user User @relation(fields: [userId], references: [id])
  gate Gate @relation(fields: [gateId], references: [id])

  @@map("access_grants")
}

model FeeClaim {
  id             String   @id @default(uuid())
  creatorId      String   @map("creator_id")
  tokenId        String   @map("token_id")
  amountLamports BigInt   @map("amount_lamports")
  amountUsd      Decimal? @map("amount_usd") @db.Decimal(18, 6)
  txSignature    String   @map("tx_signature")
  claimedAt      DateTime @default(now()) @map("claimed_at")

  creator User  @relation(fields: [creatorId], references: [id])
  token   Token @relation(fields: [tokenId], references: [id])

  @@map("fee_claims")
}

model Referral {
  id           String   @id @default(uuid())
  referrerId   String   @map("referrer_id")
  referredId   String   @map("referred_id")
  tokenId      String?  @map("token_id")
  referralCode String   @unique @map("referral_code")
  feeBps       Int      @default(0) @map("fee_bps")
  createdAt    DateTime @default(now()) @map("created_at")

  referrer User   @relation("referrer", fields: [referrerId], references: [id])
  referred User   @relation("referred", fields: [referredId], references: [id])
  token    Token? @relation(fields: [tokenId], references: [id])

  @@map("referrals")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}
